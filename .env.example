# ╔══════════════════════════════════════════════════════════╗
# ║  DUTO — PASSA FÁCIL · Variáveis de Ambiente              ║
# ║  Copie este arquivo para .env e preencha os valores      ║
# ║  NUNCA suba o arquivo .env para o GitHub                 ║
# ╚══════════════════════════════════════════════════════════╝


# ─────────────────────────────────────────────────────────
# SUPABASE
# Dashboard → Settings → API
# ─────────────────────────────────────────────────────────
SUPABASE_URL=https://XXXXXXXXXXXXXXXX.supabase.co
SUPABASE_ANON_KEY=eyJhbGc...          # chave pública (anon/public)
SUPABASE_SERVICE_KEY=eyJhbGc...       # chave privada (service_role) — só no webhook


# ─────────────────────────────────────────────────────────
# MERCADO PAGO
# Dashboard do MP → Suas integrações → Credenciais de produção
# ─────────────────────────────────────────────────────────
MP_ACCESS_TOKEN=APP_USR-000000000000000-000000-...
MP_WEBHOOK_SECRET=SEU_SECRET_AQUI     # gerado ao configurar webhook no painel do MP

# IDs dos planos no MP — gerados ao rodar criar_planos_mp() pela primeira vez
MP_PLAN_ID_PROF=2c9380848...
MP_PLAN_ID_EMP=2c9380849...


# ─────────────────────────────────────────────────────────
# APP
# ─────────────────────────────────────────────────────────
# URL pública do Streamlit Cloud (ou Railway/Render em produção)
APP_BASE_URL=https://duto-passa-facil.streamlit.app
