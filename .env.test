# ╔══════════════════════════════════════════════════════════╗
# ║  DUTO — PASSA FÁCIL · Ambiente de TESTE / SANDBOX        ║
# ║  Copie para .env ao rodar os testes manuais              ║
# ║  NUNCA use credenciais de produção neste arquivo         ║
# ╚══════════════════════════════════════════════════════════╝


# ─────────────────────────────────────────────────────────
# SUPABASE — projeto separado só para dev/teste
# Crie um projeto diferente do de produção em supabase.com
# ─────────────────────────────────────────────────────────
SUPABASE_URL=https://PROJETO-TESTE.supabase.co
SUPABASE_ANON_KEY=eyJhbGc...chave-do-projeto-de-teste
SUPABASE_SERVICE_KEY=eyJhbGc...service-key-do-projeto-de-teste


# ─────────────────────────────────────────────────────────
# MERCADO PAGO — credenciais de SANDBOX (não cobram de verdade)
# Painel MP → Suas integrações → Credenciais de teste
# ─────────────────────────────────────────────────────────
MP_ACCESS_TOKEN=TEST-0000000000000000-000000-xxxxxxxxxxxx-000000000

# Secret pode ser qualquer string no sandbox
MP_WEBHOOK_SECRET=sandbox-secret-qualquer

# IDs de plano no sandbox (gerados ao rodar criar_planos_mp() com token TEST-)
MP_PLAN_ID_PROF=
MP_PLAN_ID_EMP=


# ─────────────────────────────────────────────────────────
# APP
# ─────────────────────────────────────────────────────────
APP_BASE_URL=http://localhost:8501


# ─────────────────────────────────────────────────────────
